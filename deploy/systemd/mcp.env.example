# /etc/goalops/mcp.env — read by goalops-mcp.service via EnvironmentFile.
#
# Copy this file to /etc/goalops/mcp.env on the server and fill in the values
# you actually want. `chmod 640` and `chown root:goalops` so only the service
# user can read it (it may contain superuser creds).

# Transport: stdio (default, for local Claude Desktop) or http (for the
# server-side deployment).
MCP_TRANSPORT=http

# HTTP listener — keep on loopback; Caddy fronts it.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8765

# PocketBase backing store. Loopback, same box as the MCP server.
POCKETBASE_URL=http://127.0.0.1:8090

# Optional: log into PB as a superuser at startup so the MCP can bypass
# collection rules. Leave both blank if you want to rely on open guest rules
# (the migration 1778063864_goalops_open_guest_rules.js sets those up).
#POCKETBASE_ADMIN_EMAIL=admin@example.com
#POCKETBASE_ADMIN_PASSWORD=change-me

# Alternative: pre-acquired auth token (takes precedence over email/password).
#POCKETBASE_AUTH_TOKEN=
